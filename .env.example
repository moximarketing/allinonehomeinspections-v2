# Resend email delivery (required for form submissions to send)
# When RESEND_API_KEY is unset, the form API routes fall back to stub mode:
# they log the payload server-side and return 200 {ok:true, mode:"stub"} without sending email.
# Resend is wired at final domain cutover, NOT during staging.
RESEND_API_KEY=

# Verified sender on your Resend domain — BARE email address only (e.g. "noreply@allinonehomeinspections.com").
# The display name is applied at runtime; do NOT wrap in a display-name format here.
RESEND_FROM=

# Optional override for recipient address (defaults to the office inbox)
RESEND_TO=

# Optional BCC recipient(s) for every form submission email.
# Moxi standard: set to hello@thisismoxi.com so Moxi gets a silent copy of every lead.
RESEND_BCC=hello@thisismoxi.com
